# ── Binance Testnet credentials ──────────────────────────────────────────────
# Get keys at: https://testnet.binance.vision/
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here
TESTNET=true

# ── Trading pair ─────────────────────────────────────────────────────────────
SYMBOL=BTCUSDT
INTERVAL=1h

# ── Strategy parameters ───────────────────────────────────────────────────────
# Fraction of normalised score required to trigger BUY/SELL  (0.0 – 1.0)
CONSENSUS_THRESHOLD=0.65

# ── Risk management ───────────────────────────────────────────────────────────
# Fraction of account balance risked per trade  (e.g. 0.01 = 1 %)
RISK_PER_TRADE=0.01
# Hard ceiling: position value may never exceed this fraction of balance
MAX_POSITION_PCT=0.05

# ── Backtest ─────────────────────────────────────────────────────────────────
BACKTEST_DAYS=180
RUN_SIGNAL_EXPERIMENTS=false
RUN_EXIT_EXPERIMENTS=false
RUN_WALK_FORWARD_RESEARCH=false
RUN_RANGE_EXIT_RESEARCH=false
RUN_ENTRY_PROFILE_RESEARCH=false
RUN_ENTRY_ALTERNATIVE_HORIZONS=false
RUN_ENTRY_DIAGNOSIS=false
RUN_RANGE_MEAN_REVERSION=false
RESEARCH_BREAKOUT_LOOKBACK=20
RESEARCH_BREAKOUT_MIN_VOLUME_RATIO=1.5
RESEARCH_BREAKOUT_REQUIRE_RETEST=false
RESEARCH_PULLBACK_LOOKBACK=12
RESEARCH_RECLAIM_LOOKBACK=3
RESEARCH_RANGE_LOOKBACK=24
RESEARCH_RANGE_MIN_VWAP_BUCKET=medium

# ── Operational ──────────────────────────────────────────────────────────────
# Number of historical candles to keep in memory for indicator calculation
LOOKBACK_CANDLES=300
LOG_LEVEL=INFO
